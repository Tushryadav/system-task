# ─────────────────────────────────────────────────────────────
#  .env.example — SRAAS API
#  Copy this to .env and fill in real values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase / any Postgres) ──────────────────────
ConnectionStrings__DefaultConnection=Host=your-supabase-host.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.yourprojectref;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# ── JWT ──────────────────────────────────────────────────────
Jwt__Secret=YourStrongSecretKeyHere-MinimumOf32Characters!!
Jwt__Issuer=SRAAS.Api
Jwt__Audience=SRAAS.Client

# ── CORS (comma-separated origins for production) ────────────
# For production set your real frontend domain
Cors__AllowedOrigins__0=https://your-frontend.com

# ── ASP.NET Core environment ─────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
